pipeline {
    agent any

    tools {
        maven 'Maven3'
        jdk 'JDK21'
    }

    environment {
        ANYPOINT_CREDS = credentials('anypoint-creds')
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Build') {
            steps {
                bat 'mvn clean package -DskipTests'
            }
        }

        stage('Test') {
            steps {
                bat 'mvn test'
            }
        }

        stage('Deploy to CloudHub') {
            steps {
                bat """
                    mvn deploy -DmuleDeploy ^
                    -Danypoint.username=%ANYPOINT_CREDS_USR% ^
                    -Danypoint.password=%ANYPOINT_CREDS_PSW% ^
                    -DskipTests
                """
            }
        }

    }

    post {
        success {
            echo 'Deployed to CloudHub successfully!'
        }
        failure {
            echo 'Deployment failed!'
        }
    }
}