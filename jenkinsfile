pipeline {
    agent any

    tools {
        maven 'Maven3'
        jdk 'JDK21'
    }

    environment {
        ANYPOINT_CREDS = credentials('anypoint-creds')
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Build') {
            steps {
                bat 'mvn clean package -DskipTests'
            }
        }

        stage('Test') {
            steps {
                bat 'mvn test'
            }
        }

        // ✅ NEW STAGE (IMPORTANT)
        stage('Publish to Exchange') {
            steps {
                bat """
                    mvn clean deploy ^
                    -Danypoint.username=%ANYPOINT_CREDS_USR% ^
                    -Danypoint.password=%ANYPOINT_CREDS_PSW% ^
                    -DskipTests
                """
            }
        }

        // ✅ FIXED DEPLOY STAGE
        stage('Deploy to CloudHub') {
            steps {
                bat """
                    mvn mule:deploy ^
                    -DmuleDeploy ^
                    -Danypoint.username=%ANYPOINT_CREDS_USR% ^
                    -Danypoint.password=%ANYPOINT_CREDS_PSW%
                """
            }
        }

    }

    post {
        success {
            echo 'Application deployed successfully to CloudHub 🚀'
        }
        failure {
            echo 'Deployment failed ❌'
        }
    }
}